{
  "manifest_version": 3,
  "name": "TubeCraft for YouTube",
  "version": "1.0.0",
  "description": "Modernizes the YouTube video player, providing a sleek, dynamic, and next-generation viewing experience.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/craft-1.png",
      "48": "images/craft-1.png",
      "128": "images/craft-1.png"
    }
  },
  "icons": {
    "16": "images/craft-1.png",
    "48": "images/craft-1.png",
    "128": "images/craft-1.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
